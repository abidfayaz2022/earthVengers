{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "devCommand": "pnpm --filter @workspace/climate-change run dev",
  "outputDirectory": "artifacts/climate-change/dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/src/data/**",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
